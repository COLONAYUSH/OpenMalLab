# OpenMalLab environment. Copy to `.env` (docker compose reads it automatically).
# The Phase-1 sovereign-live defaults are baked into deploy/compose.ai.yaml; set
# values here only to override them.

# --- AI plane model: sovereign LOCAL Ollama by default ---------------------
# The model the local ollama container serves AND the one `make bootstrap-model`
# pulls into its volume. Smaller = faster on a CPU-only box.
MAL_MODEL_NAME=llama3.2:3b

# --- guarded CLOUD model (optional, explicit opt-in; overrides the local one) -
# Point at a remote OpenAI-compatible endpoint and acknowledge egress. Leave these
# unset for the air-gapped local path. Evidence is minimized before it leaves the
# box (hash + filesystem paths dropped), and a public host is refused unless
# MAL_ALLOW_CLOUD=1 is set (a container/private host needs no opt-in).
# MAL_MODEL_URL=https://your-openai-compatible-endpoint
# MAL_MODEL_KEY=your-api-key
# MAL_ALLOW_CLOUD=1

# --- self-consistency (optional): N-sample agreement measurement -------------
# 1 (default) = off. >1 re-samples the capability reasoner at a non-zero
# temperature to measure agreement (adds latency; bounded to 5).
# MAL_SELF_CONSISTENCY_SAMPLES=1

# --- build: private pip index (Artifactory) for the Python images ------------
# On a corporate network, point at your credentialed pip.conf so the mal-agents /
# capa / floss images build. On a clean network leave unset (public PyPI).
# MAL_PIP_CONF=/Users/you/.pip/pip.conf

# --- optional self-hosted Langfuse observability -----------------------------
# MAL_LANGFUSE_URL=
# MAL_LANGFUSE_PUBLIC_KEY=
# MAL_LANGFUSE_SECRET_KEY=
